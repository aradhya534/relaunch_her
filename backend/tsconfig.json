{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "lib": ["es2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
    "noImplicitAny": false,
    "resolveJsonModule": true
  },
  "include": ["index.ts", "routes/**/*.ts", "controllers/**/*.ts", "middleware/**/*.ts", "prisma/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
